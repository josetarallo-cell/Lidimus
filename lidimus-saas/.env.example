# Banco de dados
DATABASE_URL=postgresql://lidimus:lidimus@postgres:5432/lidimus

# Redis
REDIS_URL=redis://redis:6379

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production-32-chars-min
BETTER_AUTH_URL=http://localhost:3000

# n8n — webhooks de entrada (URLs dos workflows no n8n externo)
N8N_BASE_URL=https://gvlar.com/n8n
N8N_MATRICULA_WEBHOOK_PATH=/webhook/tradutor-matriculas
N8N_KML_WEBHOOK_PATH=/webhook/descritor-kml
N8N_INJECTION_WEBHOOK_PATH=/webhook/pdf-report-analyzer

# Segredo compartilhado entre Nuxt e n8n para validar callbacks
N8N_CALLBACK_SECRET=change-me-shared-with-n8n

# URL pública do Nuxt (usada pelo n8n para baixar arquivos e fazer callback)
PUBLIC_BASE_URL=http://localhost:3000

# Google Cloud Vision AI
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_SA_KEY_JSON=

# Claude API (para uso futuro direto nos workers)
ANTHROPIC_API_KEY=
